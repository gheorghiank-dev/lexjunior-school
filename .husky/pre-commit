#!/usr/bin/env sh

# LJEL pre-commit hook (safe mode for Windows + GitHub Desktop)

# Permitem bypass cu: HUSKY=0 git commit -m "..."
if [ "$HUSKY" = "0" ]; then
  echo "⚠️  Hooks disabled via HUSKY=0, skipping helper messages."
  exit 0
fi

echo "🔍 Reminder: room validator is NOT run automatically."
echo "    Run manually when you want a full check:"
echo "    npm run validate-room-content"
echo ""

echo "📦 Reminder: ZIP for AI is NOT created automatically."
echo "    Run manually when needed:"
echo "    npm run zip-for-ai"
echo ""

echo "💾 Reminder: backup is NOT created automatically."
echo "    Run manually when needed:"
echo "    npm run backup-project"
echo ""

echo "✅ Pre-commit hook finished (no blocking checks run)."
exit 0